{
  "name": "@ispmanager/db",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./generated/client/index.js",
  "types": "./generated/client/index.d.ts",
  "exports": {
    ".": {
      "types": "./generated/client/index.d.ts",
      "default": "./generated/client/index.js"
    }
  },
  "scripts": {
    "prisma:format": "prisma format --schema ./prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema ./prisma/schema.prisma",
    "db:seed": "node --import tsx ./src/seed.ts",
    "prisma:migrate:status": "prisma migrate status --schema ./prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema ./prisma/schema.prisma",
    "prisma:migrate:dev": "node ./scripts/run-safe-migrate-dev.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.3"
  },
  "devDependencies": {
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
